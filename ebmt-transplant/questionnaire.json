    },
    {
      "linkId": "outputs",
      "type": "group",
      "text": "Outputs",
      "item": [
        {
          "linkId": "score",
          "text": "EBMT risk score (0–7)",
          "type": "decimal",
          "readOnly": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "totalScore",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.answer.value.weight().sum()"
              }
            },
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "%totalScore"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-itemControl",
              "valueCodeableConcept": {
                "coding": [
                  {
                    "system": "http://fhir.tiro.health/CodeSystem/tiro-questionnaire-item-control",
                    "code": "decimal-field"
                  }
                ]
              }
            }
          ]
        },
        {
          "linkId": "risk_category",
          "text": "Risk category",
          "type": "string",
          "readOnly": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "totalScore",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.answer.value.weight().sum()"
              }
            },
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "iif(%totalScore <= 2, 'Low', iif(%totalScore <= 4, 'Intermediate', 'High'))"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-itemControl",
              "valueCodeableConcept": {
                "coding": [
                  {
                    "system": "http://fhir.tiro.health/CodeSystem/tiro-questionnaire-item-control",
                    "code": "text-field"
                  }
                ]
              }
            }
          ]
        },
        {
          "linkId": "os_5yr_pct",
          "text": "Predicted 5-year overall survival (%)",
          "type": "decimal",
          "readOnly": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "totalScore",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.answer.value.weight().sum()"
              }
            },
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "iif(%totalScore = 0, 71, iif(%totalScore = 1, 63, iif(%totalScore = 2, 55, iif(%totalScore = 3, 47, iif(%totalScore = 4, 38, iif(%totalScore = 5, 32, iif(%totalScore = 6, 26, 24)))))))"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-itemControl",
              "valueCodeableConcept": {
                "coding": [
                  {
                    "system": "http://fhir.tiro.health/CodeSystem/tiro-questionnaire-item-control",
                    "code": "decimal-field"
                  }
                ]
              }
            }
          ]
        },
        {
          "linkId": "trm_5yr_pct",
          "text": "Predicted 5-year transplant-related mortality (%)",
          "type": "decimal",
          "readOnly": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "totalScore",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.answer.value.weight().sum()"
              }
            },
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "iif(%totalScore = 0, 14, iif(%totalScore = 1, 20, iif(%totalScore = 2, 26, iif(%totalScore = 3, 32, iif(%totalScore = 4, 38, iif(%totalScore = 5, 46, iif(%totalScore = 6, 52, 56)))))))"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-itemControl",
              "valueCodeableConcept": {
                "coding": [
                  {
                    "system": "http://fhir.tiro.health/CodeSystem/tiro-questionnaire-item-control",
                    "code": "decimal-field"
                  }
                ]
              }
            }
          ]
        },
        {
          "linkId": "clinical_interpretation",
          "text": "Clinical interpretation",
          "type": "string",
          "readOnly": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "totalScore",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.answer.value.weight().sum()"
              }
            },
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "iif(%totalScore <= 2, 'Acceptable transplant risk; standard allo-HCT pathway is appropriate.', iif(%totalScore <= 4, 'Counsel about substantial mortality risk; consider HCT-CI co-assessment, optimisation of modifiable factors, and reduced-intensity conditioning where indicated.', 'Discuss alternative strategies — clinical-trial enrolment, RIC, alternative graft source, or non-transplant approaches; expected 5-yr OS <30%.'))"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-itemControl",
              "valueCodeableConcept": {
                "coding": [
                  {
                    "system": "http://fhir.tiro.health/CodeSystem/tiro-questionnaire-item-control",
                    "code": "text-field"
                  }
                ]
              }
            }
          ]
        }
      ]
    }
  ]
