          ],
          "answerOption": [
            {
              "extension": [
                {
                  "url": "http://hl7.org/fhir/StructureDefinition/itemWeight",
                  "valueDecimal": 0
                }
              ],
              "valueCoding": {
                "system": "http://calculators.tiro.health/CodeSystem/ebmt-transplant",
                "code": "lt_20",
                "display": "< 20 years"
              }
            },
            {
              "extension": [
                {
                  "url": "http://hl7.org/fhir/StructureDefinition/itemWeight",
                  "valueDecimal": 1
                }
              ],
              "valueCoding": {
                "system": "http://calculators.tiro.health/CodeSystem/ebmt-transplant",
                "code": "20_40",
                "display": "20–40 years"
              }
            },
            {
              "extension": [
                {
                  "url": "http://hl7.org/fhir/StructureDefinition/itemWeight",
                  "valueDecimal": 2
                }
              ],
              "valueCoding": {
                "system": "http://calculators.tiro.health/CodeSystem/ebmt-transplant",
                "code": "gt_40",
                "display": "> 40 years"
              }
            }
          ]
        },
        {
