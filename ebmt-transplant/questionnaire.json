{
  "resourceType": "Questionnaire",
  "name": "EbmtTransplant",
  "title": "EBMT (Gratwohl) Risk Score for Allogeneic Hematopoietic Stem Cell Transplantation",
  "status": "active",
  "subjectType": "Patient",
  "description": "Pre-transplant clinical prediction rule (sum of five 0/1/2-point components, range 0–7) for stratifying 5-year overall survival and transplant-related mortality in candidates for allogeneic HSCT. Source: Gratwohl A et al., Lancet 1998;352(9134):1087–1092; Gratwohl A et al., Cancer 2009;115(20):4715–4726; Gratwohl A, Bone Marrow Transplantation 2012;47(6):749–756.",
  "item": [
    {
      "linkId": "inputs",
      "type": "group",
      "text": "Inputs",
      "item": [
        {
          "linkId": "age_band",
          "text": "Age of recipient at transplant",
          "type": "coding",
          "required": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-itemControl",
              "valueCodeableConcept": {
                "coding": [
