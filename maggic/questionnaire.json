                "expression": "iif(%bmi < 15, 6, iif(%bmi < 20, 5, iif(%bmi < 25, 3, iif(%bmi < 30, 2, 0))))"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "creatPoints",
                "language": "text/fhirpath",
                "expression": "iif(%creat < 90, 0, iif(%creat < 110, 1, iif(%creat < 130, 2, iif(%creat < 150, 3, iif(%creat < 170, 4, iif(%creat < 210, 5, iif(%creat < 250, 6, 8)))))))"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "nyhaPoints",
                "language": "text/fhirpath",
                "expression": "iif(%nyha = 'I', 0, iif(%nyha = 'II', 2, iif(%nyha = 'III', 6, 8)))"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "binaryPoints",
                "language": "text/fhirpath",
                "expression": "iif(%male, 1, 0) + iif(%smoker, 1, 0) + iif(%dm, 3, 0) + iif(%copd, 2, 0) + iif(%hfChronic, 2, 0) + iif(%bb, 0, 3) + iif(%aceiArb, 0, 1)"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "totalPoints",
                "language": "text/fhirpath",
                "expression": "%efPoints + %agePoints + %sbpPoints + %bmiPoints + %creatPoints + %nyhaPoints + %binaryPoints"
              }
            },
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "iif(%totalPoints <= 16, 'low', iif(%totalPoints <= 20, 'low-intermediate', iif(%totalPoints <= 24, 'intermediate', iif(%totalPoints <= 28, 'intermediate-high', iif(%totalPoints <= 32, 'high', 'very-high')))))"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-itemControl",
              "valueCodeableConcept": {
                "coding": [
                  {
                    "system": "http://fhir.tiro.health/CodeSystem/tiro-questionnaire-item-control",
                    "code": "text-field"
                  }
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}