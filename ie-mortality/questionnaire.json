    {
      "linkId": "outputs",
      "type": "group",
      "text": "Outputs",
      "item": [
        {
          "linkId": "score",
          "text": "IE 6-month mortality score",
          "type": "decimal",
          "readOnly": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "ageCode",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.where(linkId='age_band').answer.value.code"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "valveCode",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.where(linkId='valve_type').answer.value.code"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "pathCode",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.where(linkId='pathogen').answer.value.code"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "totalScore",
                "language": "text/fhirpath",
                "expression": "iif(%ageCode = '46-60', 2, iif(%ageCode = '61-70', 3, iif(%ageCode = 'gt-70', 4, 0))) + iif(%resource.item.where(linkId='inputs').item.where(linkId='history_of_dialysis').answer.value.code = 'yes', 3, 0) + iif(%resource.item.where(linkId='inputs').item.where(linkId='nosocomial').answer.value.code = 'yes', 2, 0) + iif(%valveCode = 'PVE' or %valveCode = 'device', 1, 0) + iif(%resource.item.where(linkId='inputs').item.where(linkId='symptoms_gt_1_month').answer.value.code = 'yes', -1, 0) + iif(%pathCode = 's_aureus', 1, iif(%pathCode = 'vgs', -2, 0)) + iif(%resource.item.where(linkId='inputs').item.where(linkId='aortic_vegetation').answer.value.code = 'yes', 1, 0) + iif(%resource.item.where(linkId='inputs').item.where(linkId='mitral_vegetation').answer.value.code = 'yes', 1, 0) + iif(%resource.item.where(linkId='inputs').item.where(linkId='nyha_3_or_4_heart_failure').answer.value.code = 'yes', 3, 0) + iif(%resource.item.where(linkId='inputs').item.where(linkId='stroke').answer.value.code = 'yes', 2, 0) + iif(%resource.item.where(linkId='inputs').item.where(linkId='paravalvular_complication').answer.value.code = 'yes', 2, 0) + iif(%resource.item.where(linkId='inputs').item.where(linkId='persistent_bacteremia').answer.value.code = 'yes', 2, 0) + iif(%resource.item.where(linkId='inputs').item.where(linkId='surgical_treatment').answer.value.code = 'yes', -2, 0)"
              }
            },
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "%totalScore"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-itemControl",
              "valueCodeableConcept": {
                "coding": [
                  {
                    "system": "http://fhir.tiro.health/CodeSystem/tiro-questionnaire-item-control",
                    "code": "decimal-field"
                  }
                ]
              }
            }
          ]
        },
        {
          "linkId": "probability_6mo_mortality",
          "text": "Predicted 6-month all-cause mortality (probability, 0-1)",
          "type": "decimal",
          "readOnly": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "ageCode",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.where(linkId='age_band').answer.value.code"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "valveCode",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.where(linkId='valve_type').answer.value.code"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "pathCode",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.where(linkId='pathogen').answer.value.code"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "totalScore",
                "language": "text/fhirpath",
                "expression": "iif(%ageCode = '46-60', 2, iif(%ageCode = '61-70', 3, iif(%ageCode = 'gt-70', 4, 0))) + iif(%resource.item.where(linkId='inputs').item.where(linkId='history_of_dialysis').answer.value.code = 'yes', 3, 0) + iif(%resource.item.where(linkId='inputs').item.where(linkId='nosocomial').answer.value.code = 'yes', 2, 0) + iif(%valveCode = 'PVE' or %valveCode = 'device', 1, 0) + iif(%resource.item.where(linkId='inputs').item.where(linkId='symptoms_gt_1_month').answer.value.code = 'yes', -1, 0) + iif(%pathCode = 's_aureus', 1, iif(%pathCode = 'vgs', -2, 0)) + iif(%resource.item.where(linkId='inputs').item.where(linkId='aortic_vegetation').answer.value.code = 'yes', 1, 0) + iif(%resource.item.where(linkId='inputs').item.where(linkId='mitral_vegetation').answer.value.code = 'yes', 1, 0) + iif(%resource.item.where(linkId='inputs').item.where(linkId='nyha_3_or_4_heart_failure').answer.value.code = 'yes', 3, 0) + iif(%resource.item.where(linkId='inputs').item.where(linkId='stroke').answer.value.code = 'yes', 2, 0) + iif(%resource.item.where(linkId='inputs').item.where(linkId='paravalvular_complication').answer.value.code = 'yes', 2, 0) + iif(%resource.item.where(linkId='inputs').item.where(linkId='persistent_bacteremia').answer.value.code = 'yes', 2, 0) + iif(%resource.item.where(linkId='inputs').item.where(linkId='surgical_treatment').answer.value.code = 'yes', -2, 0)"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "lp",
                "language": "text/fhirpath",
                "expression": "-4.849 + 2.416 * %totalScore + 0.109 * (%totalScore * %totalScore)"
              }
            },
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "iif(%lp > 30, 1.0, iif(%lp < -30, 0.0, %lp.exp() / (1 + %lp.exp())))"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-itemControl",
              "valueCodeableConcept": {
                "coding": [
                  {
                    "system": "http://fhir.tiro.health/CodeSystem/tiro-questionnaire-item-control",
                    "code": "decimal-field"
                  }
                ]
              }
            }
          ]
        },
