    {
      "linkId": "outputs",
      "type": "group",
      "text": "Outputs",
      "item": [
        {
          "linkId": "score",
          "text": "ORBIT bleeding score (0–7)",
          "type": "decimal",
          "readOnly": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "totalScore",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.answer.value.weight().sum()"
              }
            },
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "%totalScore"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-itemControl",
              "valueCodeableConcept": {
                "coding": [
                  {
                    "system": "http://fhir.tiro.health/CodeSystem/tiro-questionnaire-item-control",
                    "code": "decimal-field"
                  }
                ]
              }
            }
          ]
        },
        {
          "linkId": "risk_band",
          "text": "Risk band",
          "type": "string",
          "readOnly": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "totalScore",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.answer.value.weight().sum()"
              }
            },
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "iif(%totalScore <= 2, 'low', iif(%totalScore = 3, 'medium', 'high'))"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-itemControl",
              "valueCodeableConcept": {
                "coding": [
                  {
                    "system": "http://fhir.tiro.health/CodeSystem/tiro-questionnaire-item-control",
                    "code": "text-field"
                  }
                ]
              }
            }
          ]
        },
        {
          "linkId": "rate_per_100_py",
          "text": "Major bleeds per 100 patient-years (per-score rate)",
          "type": "decimal",
          "readOnly": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "totalScore",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.answer.value.weight().sum()"
              }
            },
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "iif(%totalScore = 0, 1.7, iif(%totalScore = 1, 2.3, iif(%totalScore = 2, 2.9, iif(%totalScore = 3, 4.7, iif(%totalScore = 4, 6.8, 9.0)))))"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-itemControl",
              "valueCodeableConcept": {
                "coding": [
                  {
                    "system": "http://fhir.tiro.health/CodeSystem/tiro-questionnaire-item-control",
                    "code": "decimal-field"
                  }
                ]
              }
            }
          ]
        },
        {
          "linkId": "rate_ci_low",
          "text": "Lower 95% CI for per-score rate",
          "type": "decimal",
          "readOnly": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "totalScore",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.answer.value.weight().sum()"
              }
            },
            {
