{
  "resourceType": "Questionnaire",
  "name": "OrbitBleeding",
  "title": "ORBIT Bleeding Score for Atrial Fibrillation",
  "status": "active",
  "subjectType": "Patient",
  "description": "Bedside score predicting major bleeding in patients with atrial fibrillation on oral anticoagulation. Five clinical/laboratory variables sum to a 0–7 score mapping to low/medium/high bleeding-risk bands. Source: O'Brien EC et al., Eur Heart J 2015;36(46):3258–3264.",
  "item": [
