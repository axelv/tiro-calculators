    {
      "linkId": "outputs",
      "type": "group",
      "text": "Outputs",
      "extension": [
        {
          "url": "http://hl7.org/fhir/StructureDefinition/variable",
          "valueExpression": {
            "name": "totalScore",
            "language": "text/fhirpath",
            "expression": "%resource.item.where(linkId='inputs').item.answer.value.weight().sum()"
          }
        },
        {
          "url": "http://hl7.org/fhir/StructureDefinition/variable",
          "valueExpression": {
            "name": "sexFemale",
            "language": "text/fhirpath",
            "expression": "%resource.item.where(linkId='inputs').item.where(linkId='sex').answer.value.code = 'female'"
          }
        }
      ],
      "item": [
        {
          "linkId": "score",
          "text": "CHA₂DS₂-VASc score",
          "type": "decimal",
          "readOnly": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "%totalScore"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-itemControl",
              "valueCodeableConcept": {
                "coding": [
                  {
                    "system": "http://fhir.tiro.health/CodeSystem/tiro-questionnaire-item-control",
                    "code": "decimal-field"
                  }
                ]
              }
            }
          ]
        },
        {
          "linkId": "risk_band",
          "text": "Risk band",
          "type": "string",
          "readOnly": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "iif(%totalScore >= 7, 'very_high', iif(%totalScore >= 3, 'high', iif(%totalScore = 2, 'moderate', iif(%totalScore = 1, 'low_moderate', 'low'))))"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-itemControl",
              "valueCodeableConcept": {
                "coding": [
                  {
                    "system": "http://fhir.tiro.health/CodeSystem/tiro-questionnaire-item-control",
                    "code": "text-field"
                  }
                ]
              }
            }
          ]
        },
        {
          "linkId": "annual_stroke_risk_friberg_2012_percent",
          "text": "Annual stroke risk (Friberg 2012, % per year)",
          "type": "decimal",
          "readOnly": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "iif(%totalScore = 9, 12.2, iif(%totalScore = 8, 10.8, iif(%totalScore = 7, 11.2, iif(%totalScore = 6, 9.7, iif(%totalScore = 5, 7.2, iif(%totalScore = 4, 4.8, iif(%totalScore = 3, 3.2, iif(%totalScore = 2, 2.2, iif(%totalScore = 1, 0.6, 0.2)))))))))"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-itemControl",
              "valueCodeableConcept": {
                "coding": [
                  {
                    "system": "http://fhir.tiro.health/CodeSystem/tiro-questionnaire-item-control",
                    "code": "decimal-field"
                  }
                ]
              }
            }
          ]
        },
        {
          "linkId": "recommendation",
          "text": "Antithrombotic recommendation (ESC 2020 / AHA-ACC-HRS 2023)",
          "type": "string",
          "readOnly": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "iif(%sexFemale and %totalScore = 1, 'No antithrombotic therapy (female with sex point only — low-risk equivalent to male score 0).', iif(%sexFemale, iif(%totalScore >= 3, 'OAC recommended (Class I) — DOAC preferred in non-valvular AF unless contraindicated.', iif(%totalScore = 2, 'Consider OAC (Class IIa) — individualize based on bleeding risk and patient preference.', 'No antithrombotic therapy.')), iif(%totalScore >= 2, 'OAC recommended (Class I) — DOAC preferred in non-valvular AF unless contraindicated.', iif(%totalScore = 1, 'Consider OAC (Class IIa) — individualize based on bleeding risk and patient preference.', 'No antithrombotic therapy. Truly low-risk.'))))"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-itemControl",
              "valueCodeableConcept": {
                "coding": [
                  {
                    "system": "http://fhir.tiro.health/CodeSystem/tiro-questionnaire-item-control",
                    "code": "text-field"
                  }
                ]
              }
            }
          ]
        }
      ]
    }
  ]
