              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "scale1",
                "language": "text/fhirpath",
                "expression": "iif(%sex = 'male', iif(%region = 'low', -0.5699, iif(%region = 'moderate', -0.1565, iif(%region = 'high', 0.3207, 0.5836))), iif(%region = 'low', -0.7380, iif(%region = 'moderate', -0.3143, iif(%region = 'high', 0.5710, 0.9412))))"
