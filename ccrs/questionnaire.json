{
  "resourceType": "Questionnaire",
  "name": "Ccrs",
  "title": "CHRS / CCRS — Clonal Hematopoiesis Risk Score",
  "status": "active",
  "subjectType": "Patient",
  "description": "Clonal Hematopoiesis Risk Score (CHRS, also known as CCRS) — predicts 10-year cumulative incidence of progression from CHIP / CCUS to overt myeloid neoplasm. Weighted points sum across 8 binary features. Source: Weeks LD et al., NEJM Evidence 2023;2(5):EVIDoa2200310.",
