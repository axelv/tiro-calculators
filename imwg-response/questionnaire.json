{
  "resourceType": "Questionnaire",
  "name": "ImwgResponse",
  "title": "IMWG Multiple Myeloma Response Criteria (2016)",
  "status": "active",
  "subjectType": "Patient",
  "description": "Categorical assessment of treatment response in multiple myeloma per the International Myeloma Working Group 2016 consensus update, evaluating from the deepest response (Sustained MRD-negative) down to PD. Source: Kumar S et al., Lancet Oncol 2016;17(8):e328-e346.",
  "item": [
    {
      "linkId": "inputs",
      "type": "group",
      "text": "Inputs",
      "item": [
        {
          "linkId": "serum_m_baseline_g_dL",
          "text": "Serum M-protein at baseline (g/dL)",
          "type": "decimal",
          "required": true
        },
        {
          "linkId": "serum_m_current_g_dL",
          "text": "Serum M-protein, current (g/dL; enter 0 if undetectable on SPEP)",
          "type": "decimal",
          "required": true
        },
        {
          "linkId": "serum_m_nadir_g_dL",
          "text": "Serum M-protein nadir / best response (g/dL)",
          "type": "decimal",
          "required": true
        },
        {
          "linkId": "urine_m_baseline_mg_24h",
          "text": "Urine M-protein at baseline (mg / 24 h)",
          "type": "decimal",
          "required": true
        },
        {
          "linkId": "urine_m_current_mg_24h",
