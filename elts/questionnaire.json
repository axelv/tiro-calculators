{
  "resourceType": "Questionnaire",
  "name": "Elts",
  "title": "EUTOS Long-Term Survival (ELTS) Score for CML",
  "status": "active",
  "subjectType": "Patient",
  "description": "ELTS is a baseline prognostic score for newly-diagnosed chronic-phase chronic myeloid leukaemia (CML) that predicts the probability of CML-specific (not all-cause) death under tyrosine-kinase inhibitor therapy. Derived and validated by Pfirrmann M et al., Leukemia 2016;30(1):48-56.",
  "extension": [],
  "item": [
    {
      "linkId": "inputs",
      "type": "group",
      "text": "Inputs",
      "item": [
        {
          "linkId": "age",
          "type": "decimal",
          "text": "Age (completed years)",
          "required": true
        },
        {
          "linkId": "spleen_cm",
          "type": "decimal",
          "text": "Spleen size below costal margin (cm; 0 if not palpable)",
          "required": true
        },
        {
          "linkId": "blasts_pct",
          "type": "decimal",
          "text": "Peripheral-blood blasts (%)",
          "required": true
        },
        {
          "linkId": "platelets",
          "type": "decimal",
          "text": "Platelet count (× 10⁹/L)",
          "required": true
        }
      ]
    },
    {
      "linkId": "outputs",
      "type": "group",
      "text": "Outputs",
      "item": [
        {
          "linkId": "score",
          "type": "decimal",
          "text": "ELTS score",
          "readOnly": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-itemControl",
              "valueCodeableConcept": {
                "coding": [
                  {
                    "system": "http://fhir.tiro.health/CodeSystem/tiro-questionnaire-item-control",
                    "code": "decimal-field"
                  }
                ]
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "age",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.where(linkId='age').answer.value"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "spleen",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.where(linkId='spleen_cm').answer.value"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "blasts",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.where(linkId='blasts_pct').answer.value.round()"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "plt",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.where(linkId='platelets').answer.value"
              }
            },
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "(((0.0025 * (%age / 10).power(3) + 0.0615 * %spleen + 0.1052 * %blasts + 0.4104 * (%plt / 1000).power(-0.5)) * 10000).round()) / 10000"
              }
            }
          ]
        },
        {
          "linkId": "risk_group",
          "type": "string",
          "text": "Risk group",
          "readOnly": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-itemControl",
              "valueCodeableConcept": {
                "coding": [
                  {
                    "system": "http://fhir.tiro.health/CodeSystem/tiro-questionnaire-item-control",
                    "code": "text-field"
                  }
                ]
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "age",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.where(linkId='age').answer.value"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "spleen",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.where(linkId='spleen_cm').answer.value"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "blasts",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.where(linkId='blasts_pct').answer.value.round()"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "plt",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.where(linkId='platelets').answer.value"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "rawScore",
                "language": "text/fhirpath",
                "expression": "0.0025 * (%age / 10).power(3) + 0.0615 * %spleen + 0.1052 * %blasts + 0.4104 * (%plt / 1000).power(-0.5)"
              }
            },
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "iif(%rawScore <= 1.5680, 'Low', iif(%rawScore <= 2.2185, 'Intermediate', 'High'))"
              }
            }
          ]
        },
