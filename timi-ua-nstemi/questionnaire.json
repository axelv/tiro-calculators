    {
      "linkId": "outputs",
      "type": "group",
      "text": "Outputs",
      "item": [
        {
          "linkId": "score",
          "text": "TIMI score (0–7)",
          "type": "decimal",
          "readOnly": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "totalScore",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.answer.value.weight().sum()"
              }
            },
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "%totalScore"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-itemControl",
              "valueCodeableConcept": {
                "coding": [
                  {
                    "system": "http://fhir.tiro.health/CodeSystem/tiro-questionnaire-item-control",
                    "code": "decimal-field"
                  }
                ]
              }
            }
          ]
        },
        {
          "linkId": "composite_14d_risk_percent",
          "text": "14-day composite event rate (%)",
          "type": "decimal",
          "readOnly": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "totalScore",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.answer.value.weight().sum()"
              }
            },
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "iif(%totalScore <= 1, 4.7, iif(%totalScore = 2, 8.3, iif(%totalScore = 3, 13.2, iif(%totalScore = 4, 19.9, iif(%totalScore = 5, 26.2, 40.9)))))"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-itemControl",
              "valueCodeableConcept": {
                "coding": [
                  {
                    "system": "http://fhir.tiro.health/CodeSystem/tiro-questionnaire-item-control",
                    "code": "decimal-field"
                  }
                ]
              }
            }
          ]
        },
        {
          "linkId": "risk_band",
          "text": "Risk band",
          "type": "string",
          "readOnly": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "totalScore",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.answer.value.weight().sum()"
              }
            },
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "iif(%totalScore <= 2, 'low', iif(%totalScore <= 4, 'intermediate', 'high'))"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-itemControl",
              "valueCodeableConcept": {
                "coding": [
                  {
                    "system": "http://fhir.tiro.health/CodeSystem/tiro-questionnaire-item-control",
                    "code": "text-field"
                  }
                ]
              }
            }
          ]
        },
        {
          "linkId": "endpoint",
          "text": "Endpoint definition",
          "type": "string",
          "readOnly": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "'All-cause mortality, new/recurrent MI, or severe recurrent ischaemia requiring urgent revascularisation through 14 days'"
              }
            },
