    {
      "linkId": "outputs",
      "type": "group",
      "text": "Outputs",
      "item": [
        {
          "linkId": "score",
          "text": "HAS-BLED score",
          "type": "decimal",
          "readOnly": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "totalScore",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.answer.value.weight().sum()"
              }
            },
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "%totalScore"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-itemControl",
              "valueCodeableConcept": {
                "coding": [
                  {
                    "system": "http://fhir.tiro.health/CodeSystem/tiro-questionnaire-item-control",
                    "code": "decimal-field"
                  }
                ]
              }
            }
          ]
        },
        {
          "linkId": "risk_per_100_py",
          "text": "Bleeds per 100 patient-years (Pisters 2010)",
          "type": "string",
          "readOnly": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "totalScore",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.answer.value.weight().sum()"
              }
            },
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "iif(%totalScore = 0, '~1.13', iif(%totalScore = 1, '~1.02', iif(%totalScore = 2, '~1.88', iif(%totalScore = 3, '~3.74', iif(%totalScore = 4, '~8.70', iif(%totalScore = 5, '~12.50', 'data limited (very high)'))))))"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-itemControl",
              "valueCodeableConcept": {
                "coding": [
                  {
                    "system": "http://fhir.tiro.health/CodeSystem/tiro-questionnaire-item-control",
                    "code": "text-field"
                  }
                ]
              }
            }
          ]
        },
        {
          "linkId": "risk_category",
          "text": "Risk category",
          "type": "string",
          "readOnly": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "totalScore",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.answer.value.weight().sum()"
              }
            },
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "iif(%totalScore <= 1, 'low', iif(%totalScore = 2, 'moderate', iif(%totalScore <= 5, 'high', 'very high')))"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-itemControl",
              "valueCodeableConcept": {
                "coding": [
                  {
                    "system": "http://fhir.tiro.health/CodeSystem/tiro-questionnaire-item-control",
                    "code": "text-field"
                  }
                ]
              }
            }
          ]
        },
        {
          "linkId": "interpretation",
          "text": "Clinical interpretation",
          "type": "string",
          "readOnly": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "totalScore",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.answer.value.weight().sum()"
              }
            },
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "iif(%totalScore <= 1, 'Low bleeding risk. Anticoagulation generally favorable; routine monitoring.', iif(%totalScore = 2, 'Moderate bleeding risk. Anticoagulation generally favorable; address modifiable factors.', 'High bleeding risk. Caution and frequent review; aggressive correction of modifiable factors. Not by itself a contraindication to anticoagulation.'))"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-itemControl",
              "valueCodeableConcept": {
                "coding": [
                  {
                    "system": "http://fhir.tiro.health/CodeSystem/tiro-questionnaire-item-control",
                    "code": "text-field"
                  }
                ]
              }
            }
          ]
        }
      ]
    }
