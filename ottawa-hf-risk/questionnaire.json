              }
            },
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "iif(%histStroke, 1, 0) + iif(%histIntub, 1, 0) + iif(%hrArr, 1, 0) + iif(%sao2Arr, 1, 0) + iif(%walkHr, 1, 0) + iif(%walkSao2, 1, 0) + iif(%ecgIsch, 1, 0) + iif(%urea, 1, 0) + iif(%co2, 1, 0) + iif(%trop, 1, 0)"
              }
