{
  "resourceType": "Questionnaire",
  "name": "OttawaHfRisk",
  "title": "Ottawa Heart Failure Risk Scale (OHFRS)",
  "status": "active",
  "subjectType": "Patient",
  "description": "Stratifies emergency-department patients with acute decompensated heart failure (after initial ED therapy) by their risk of short-term serious adverse events. Supports the basic 10-item variant (1 point per criterion, range 0–10) and the quantitative variant with NT-proBNP (weighted, range 0–15). Source: Stiell IG et al., Acad Emerg Med 2013;20(1):17–26; Stiell IG et al., Acad Emerg Med 2017;24(3):316–327.",
