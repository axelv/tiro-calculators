              "valueCodeableConcept": {
                "coding": [
                  {
                    "system": "http://fhir.tiro.health/CodeSystem/tiro-questionnaire-item-control",
                    "code": "chips"
                  }
                ]
              }
            }
          ],
          "answerOption": [
            {
              "valueCoding": {
                "system": "http://calculators.tiro.health/CodeSystem/ottawa-hf-risk",
                "code": "basic",
                "display": "Basic OHFRS (10 items)"
