          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "histStroke",
                "language": "text/fhirpath",
                "expression": "%resource.repeat(item).where(linkId='history_stroke_or_tia').answer.value.code = 'yes'"
