                "expression": "iif(%sexCode = 'male', 0.3742 * %cage + 0.6012 * %smk + 0.2777 * %csbp + 0.1458 * %ctchol + (-0.2698) * %chdl + (-0.0755) * %cage * %smk + (-0.0255) * %cage * %csbp + (-0.0281) * %cage * %ctchol + 0.0426 * %cage * %chdl, 0.4648 * %cage + 0.7744 * %smk + 0.3131 * %csbp + 0.1002 * %ctchol + (-0.2606) * %chdl + (-0.1088) * %cage * %smk + (-0.0277) * %cage * %csbp + (-0.0226) * %cage * %ctchol + 0.0613 * %cage * %chdl)"
