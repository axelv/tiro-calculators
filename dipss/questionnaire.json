{
  "resourceType": "Questionnaire",
  "name": "Dipss",
  "title": "DIPSS — Dynamic International Prognostic Scoring System for Myelofibrosis",
  "status": "active",
  "subjectType": "Patient",
  "description": "Dynamic prognostic model that stratifies patients with primary myelofibrosis into four risk groups (Low, Intermediate-1, Intermediate-2, High) and reports median overall survival. Source: Passamonti F et al., Blood 2010;115(9):1703–1708.",
