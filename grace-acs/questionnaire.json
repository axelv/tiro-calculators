{
  "resourceType": "Questionnaire",
  "name": "GraceAcs",
  "title": "GRACE ACS Risk and Mortality Calculator",
  "status": "active",
  "subjectType": "Patient",
  "description": "Estimates in-hospital mortality risk for patients hospitalized with an acute coronary syndrome (STEMI / NSTEMI / unstable angina). Implements the original Granger 2003 GRACE 1.0 admission point-table nomogram and its in-hospital mortality lookup. Source: Granger CB et al., Arch Intern Med 2003;163(19):2345–2353.",
  "item": [
    {
      "linkId": "inputs",
      "type": "group",
      "text": "Inputs",
      "item": [
        {
          "linkId": "age",
          "text": "Age (years)",
          "type": "decimal",
          "required": true
        },
        {
          "linkId": "heart_rate",
          "text": "Heart rate (bpm)",
          "type": "decimal",
          "required": true
        },
        {
          "linkId": "systolic_bp",
          "text": "Systolic blood pressure (mmHg)",
          "type": "decimal",
          "required": true
        },
        {
          "linkId": "creatinine",
          "text": "Serum creatinine (mg/dL)",
          "type": "decimal",
          "required": true
        },
        {
          "linkId": "killip_class",
          "text": "Killip class",
          "type": "coding",
          "required": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-itemControl",
              "valueCodeableConcept": {
                "coding": [
                  {
                    "system": "http://fhir.tiro.health/CodeSystem/tiro-questionnaire-item-control",
                    "code": "chips"
                  }
                ]
              }
            }
          ],
          "answerOption": [
            {
              "valueCoding": {
                "system": "http://calculators.tiro.health/CodeSystem/grace-acs",
                "code": "I",
                "display": "Killip I (no CHF)"
              }
            },
            {
              "valueCoding": {
                "system": "http://calculators.tiro.health/CodeSystem/grace-acs",
                "code": "II",
                "display": "Killip II (rales / S3 / elevated JVP)"
              }
            },
            {
              "valueCoding": {
                "system": "http://calculators.tiro.health/CodeSystem/grace-acs",
                "code": "III",
                "display": "Killip III (pulmonary edema)"
              }
            },
            {
              "valueCoding": {
                "system": "http://calculators.tiro.health/CodeSystem/grace-acs",
                "code": "IV",
                "display": "Killip IV (cardiogenic shock)"
              }
            }
          ]
        },
        {
          "linkId": "cardiac_arrest_at_admission",
          "text": "Cardiac arrest at admission",
          "type": "coding",
          "required": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-itemControl",
              "valueCodeableConcept": {
                "coding": [
                  {
                    "system": "http://fhir.tiro.health/CodeSystem/tiro-questionnaire-item-control",
                    "code": "chips"
                  }
                ]
              }
            }
          ],
          "answerOption": [
            {
              "valueCoding": {
                "system": "http://calculators.tiro.health/CodeSystem/grace-acs",
                "code": "no",
                "display": "No cardiac arrest"
              }
            },
            {
              "valueCoding": {
                "system": "http://calculators.tiro.health/CodeSystem/grace-acs",
                "code": "yes",
                "display": "Cardiac arrest at admission"
              }
            }
          ]
        },
        {
          "linkId": "st_segment_deviation",
          "text": "ST-segment deviation on admission ECG",
          "type": "coding",
          "required": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-itemControl",
              "valueCodeableConcept": {
                "coding": [
                  {
                    "system": "http://fhir.tiro.health/CodeSystem/tiro-questionnaire-item-control",
                    "code": "chips"
                  }
                ]
              }
            }
          ],
          "answerOption": [
            {
              "valueCoding": {
                "system": "http://calculators.tiro.health/CodeSystem/grace-acs",
                "code": "no",
                "display": "No ST deviation"
              }
            },
            {
              "valueCoding": {
                "system": "http://calculators.tiro.health/CodeSystem/grace-acs",
                "code": "yes",
                "display": "ST-segment deviation present"
              }
            }
          ]
        },
        {
          "linkId": "elevated_cardiac_enzymes",
          "text": "Elevated cardiac enzymes (troponin or CK-MB > URL)",
          "type": "coding",
          "required": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-itemControl",
              "valueCodeableConcept": {
                "coding": [
