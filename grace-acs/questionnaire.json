            {
              "valueCoding": {
                "system": "http://calculators.tiro.health/CodeSystem/grace-acs",
                "code": "yes",
                "display": "Elevated cardiac enzymes"
              }
            }
          ]
        }
      ]
    },
    {
      "linkId": "outputs",
      "type": "group",
      "text": "Outputs",
      "item": [
        {
          "linkId": "total_points",
          "text": "GRACE total points (Granger 2003)",
          "type": "decimal",
          "readOnly": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "age",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.where(linkId='age').answer.value"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "hr",
