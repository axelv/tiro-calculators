              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "stdev",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.where(linkId='st_segment_deviation').answer.value.code = 'yes'"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "enz",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.where(linkId='elevated_cardiac_enzymes').answer.value.code = 'yes'"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "ptsAge",
                "language": "text/fhirpath",
                "expression": "iif(%age < 30, 0, iif(%age < 40, 8, iif(%age < 50, 25, iif(%age < 60, 41, iif(%age < 70, 58, iif(%age < 80, 75, iif(%age < 90, 91, 100)))))))"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "ptsHr",
                "language": "text/fhirpath",
                "expression": "iif(%hr < 50, 0, iif(%hr < 70, 3, iif(%hr < 90, 9, iif(%hr < 110, 15, iif(%hr < 150, 24, iif(%hr < 200, 38, 46))))))"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "ptsSbp",
                "language": "text/fhirpath",
                "expression": "iif(%sbp < 80, 58, iif(%sbp < 100, 53, iif(%sbp < 120, 43, iif(%sbp < 140, 34, iif(%sbp < 160, 24, iif(%sbp < 200, 10, 0))))))"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "ptsCr",
                "language": "text/fhirpath",
                "expression": "iif(%cr < 0.40, 1, iif(%cr < 0.80, 4, iif(%cr < 1.20, 7, iif(%cr < 1.60, 10, iif(%cr < 2.00, 13, iif(%cr < 4.00, 21, 28))))))"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "ptsKillip",
                "language": "text/fhirpath",
                "expression": "iif(%killip = 'I', 0, iif(%killip = 'II', 20, iif(%killip = 'III', 39, 59)))"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "ptsModifiers",
                "language": "text/fhirpath",
                "expression": "iif(%arrest, 39, 0) + iif(%stdev, 28, 0) + iif(%enz, 14, 0)"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "totalPoints",
                "language": "text/fhirpath",
                "expression": "%ptsAge + %ptsHr + %ptsSbp + %ptsCr + %ptsKillip + %ptsModifiers"
              }
            },
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "%totalPoints"
