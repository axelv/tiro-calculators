    {
      "linkId": "outputs",
      "type": "group",
      "text": "Outputs",
      "item": [
        {
          "linkId": "score",
          "text": "TRI-SCORE",
          "type": "decimal",
          "readOnly": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "totalScore",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.answer.value.weight().sum()"
              }
            },
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "%totalScore"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-itemControl",
              "valueCodeableConcept": {
                "coding": [
                  {
                    "system": "http://fhir.tiro.health/CodeSystem/tiro-questionnaire-item-control",
                    "code": "decimal-field"
                  }
                ]
              }
            }
          ]
        },
        {
          "linkId": "predicted_inhospital_mortality_pct",
          "text": "Predicted in-hospital mortality (%)",
          "type": "decimal",
          "readOnly": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "totalScore",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.answer.value.weight().sum()"
              }
            },
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "iif(%totalScore = 0, 1, iif(%totalScore = 1, 2, iif(%totalScore = 2, 3, iif(%totalScore = 3, 5, iif(%totalScore = 4, 8, iif(%totalScore = 5, 14, iif(%totalScore = 6, 22, iif(%totalScore = 7, 34, iif(%totalScore = 8, 48, 65))))))))) "
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-itemControl",
              "valueCodeableConcept": {
                "coding": [
                  {
                    "system": "http://fhir.tiro.health/CodeSystem/tiro-questionnaire-item-control",
                    "code": "decimal-field"
                  }
                ]
              }
            }
          ]
        },
        {
          "linkId": "risk_band",
          "text": "Risk band",
          "type": "string",
          "readOnly": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "totalScore",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.answer.value.weight().sum()"
              }
            },
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "iif(%totalScore <= 3, 'low', iif(%totalScore <= 5, 'intermediate', 'high'))"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-itemControl",
              "valueCodeableConcept": {
                "coding": [
                  {
                    "system": "http://fhir.tiro.health/CodeSystem/tiro-questionnaire-item-control",
                    "code": "text-field"
                  }
                ]
              }
            }
          ]
        }
      ]
