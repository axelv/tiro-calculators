{
  "resourceType": "Questionnaire",
  "name": "Mipss70",
  "title": "MIPSS70 / MIPSS70+ v2.0 — Mutation-Enhanced International Prognostic Score System for Primary Myelofibrosis",
  "status": "active",
  "subjectType": "Patient",
