          "text": "Risk category",
          "type": "string",
          "readOnly": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "version",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.where(linkId='version').answer.value.code"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "scoreMipss70",
                "language": "text/fhirpath",
                "expression": "iif(%resource.item.where(linkId='inputs').item.where(linkId='hb_lt_10').answer.value.code = 'yes', 1, 0) + iif(%resource.item.where(linkId='inputs').item.where(linkId='wbc_gt_25').answer.value.code = 'yes', 2, 0) + iif(%resource.item.where(linkId='inputs').item.where(linkId='plt_lt_100').answer.value.code = 'yes', 2, 0) + iif(%resource.item.where(linkId='inputs').item.where(linkId='blasts_ge_2').answer.value.code = 'yes', 1, 0) + iif(%resource.item.where(linkId='inputs').item.where(linkId='bm_fibrosis_ge_2').answer.value.code = 'yes', 1, 0) + iif(%resource.item.where(linkId='inputs').item.where(linkId='constitutional_symptoms').answer.value.code = 'yes', 1, 0) + iif(%resource.item.where(linkId='inputs').item.where(linkId='absence_calr_type1').answer.value.code = 'yes', 1, 0) + iif(%resource.item.where(linkId='inputs').item.where(linkId='hmr_present').answer.value.code = 'yes', 1, 0) + iif(%resource.item.where(linkId='inputs').item.where(linkId='hmr_two_or_more').answer.value.code = 'yes', 2, 0)"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "scoreMipss70V2",
                "language": "text/fhirpath",
                "expression": "iif(%resource.item.where(linkId='inputs').item.where(linkId='karyotype').answer.value.code = 'vhr', 4, iif(%resource.item.where(linkId='inputs').item.where(linkId='karyotype').answer.value.code = 'unfavorable', 3, 0)) + iif(%resource.item.where(linkId='inputs').item.where(linkId='hmr_status').answer.value.code = 'two_or_more', 3, iif(%resource.item.where(linkId='inputs').item.where(linkId='hmr_status').answer.value.code = 'single', 2, 0)) + iif(%resource.item.where(linkId='inputs').item.where(linkId='absence_calr_type1').answer.value.code = 'yes', 2, 0) + iif(%resource.item.where(linkId='inputs').item.where(linkId='constitutional_symptoms').answer.value.code = 'yes', 2, 0) + iif(%resource.item.where(linkId='inputs').item.where(linkId='severe_anemia').answer.value.code = 'yes', 2, iif(%resource.item.where(linkId='inputs').item.where(linkId='moderate_anemia').answer.value.code = 'yes', 1, 0)) + iif(%resource.item.where(linkId='inputs').item.where(linkId='blasts_ge_2').answer.value.code = 'yes', 1, 0)"
              }
            },
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "iif(%version = 'MIPSS70', iif(%scoreMipss70 <= 1, 'low', iif(%scoreMipss70 <= 4, 'intermediate', 'high')), iif(%scoreMipss70V2 = 0, 'very_low', iif(%scoreMipss70V2 <= 2, 'low', iif(%scoreMipss70V2 <= 4, 'intermediate', iif(%scoreMipss70V2 <= 8, 'high', 'very_high')))))"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-itemControl",
              "valueCodeableConcept": {
                "coding": [
                  {
                    "system": "http://fhir.tiro.health/CodeSystem/tiro-questionnaire-item-control",
                    "code": "text-field"
                  }
                ]
              }
            }
