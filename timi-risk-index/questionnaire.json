{
  "resourceType": "Questionnaire",
  "name": "TimiRiskIndex",
  "title": "TIMI Risk Index (TRI)",
  "status": "active",
  "subjectType": "Patient",
  "description": "Bedside short-term mortality estimate for Acute Coronary Syndrome (STEMI and UA/NSTEMI) using only admission heart rate, systolic blood pressure, and age. Derived in the InTIME II STEMI cohort (Morrow DA et al., Lancet 2001;358:1571-1575).",
  "item": [
    {
      "linkId": "inputs",
      "type": "group",
      "text": "Inputs",
      "item": [
        {
          "linkId": "heart_rate",
          "type": "decimal",
          "text": "Admission heart rate (bpm)",
          "required": true
        },
        {
          "linkId": "systolic_bp",
          "type": "decimal",
          "text": "Admission systolic blood pressure (mmHg)",
          "required": true
        },
        {
          "linkId": "age",
          "type": "decimal",
          "text": "Age (years)",
          "required": true
        }
      ]
    },
    {
      "linkId": "outputs",
      "type": "group",
      "text": "Outputs",
      "item": [
        {
          "linkId": "tri",
          "text": "TIMI Risk Index",
          "type": "decimal",
          "readOnly": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "hr",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.where(linkId='heart_rate').answer.value.first()"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "sbp",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.where(linkId='systolic_bp').answer.value.first()"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "age",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.where(linkId='age').answer.value.first()"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-itemControl",
              "valueCodeableConcept": {
                "coding": [
                  {
                    "system": "http://fhir.tiro.health/CodeSystem/tiro-questionnaire-item-control",
                    "code": "decimal-field"
                  }
                ]
              }
            },
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "(%hr * (%age / 10).power(2)) / %sbp"
              }
            }
          ]
        },
        {
          "linkId": "quintile",
          "text": "Quintile (1-5)",
          "type": "decimal",
          "readOnly": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "hr",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.where(linkId='heart_rate').answer.value.first()"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "sbp",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.where(linkId='systolic_bp').answer.value.first()"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "age",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.where(linkId='age').answer.value.first()"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
              "valueExpression": {
                "name": "tri",
                "language": "text/fhirpath",
                "expression": "(%hr * (%age / 10).power(2)) / %sbp"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-itemControl",
              "valueCodeableConcept": {
                "coding": [
                  {
                    "system": "http://fhir.tiro.health/CodeSystem/tiro-questionnaire-item-control",
                    "code": "decimal-field"
                  }
                ]
              }
            },
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "iif(%tri >= 30.0, 5, iif(%tri >= 22.5, 4, iif(%tri >= 17.5, 3, iif(%tri >= 12.5, 2, 1))))"
              }
            }
          ]
        },
