                "name": "treatedBp",
                "language": "text/fhirpath",
                "expression": "%resource.item.where(linkId='inputs').item.where(linkId='on_antihypertensive').answer.value.code = 'yes'"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/variable",
