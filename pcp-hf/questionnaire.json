                "expression": "iif(%raceCode = 'white' and %sexCode = 'male', 41.94 * %lnAge + (-0.88) * %lnAge.power(2) + iif(%treatedBp, 1.03 * %lnSbp, 0.91 * %lnSbp) + iif(%smoker, 0.74, 0) + iif(%treatedDm, 0.90 * %lnGlu, 0.78 * %lnGlu) + 0.49 * %lnTc + (-0.44) * %lnHdl + 37.20 * %lnBmi + (-8.83) * %lnAge * %lnBmi + 0.63 * %lnQrs, iif(%raceCode = 'white' and %sexCode = 'female', 20.55 * %lnAge + iif(%treatedBp, 12.95 * %lnSbp + (-2.96) * %lnAge * %lnSbp, 11.86 * %lnSbp + (-2.73) * %lnAge * %lnSbp) + iif(%smoker, 11.02 + (-2.50) * %lnAge, 0) + iif(%treatedDm, 1.04 * %lnGlu, 0.91 * %lnGlu) + (-0.07) * %lnHdl + 1.33 * %lnBmi + 1.06 * %lnQrs, iif(%raceCode = 'black' and %sexCode = 'male', 2.88 * %lnAge + iif(%treatedBp, 2.31 * %lnSbp, 2.17 * %lnSbp) + iif(%smoker, 1.66 + (-0.25) * %lnAge, 0) + iif(%treatedDm, 0.64 * %lnGlu, 0.58 * %lnGlu) + (-0.81) * %lnHdl + 1.16 * %lnBmi + 0.73 * %lnQrs, 51.75 * %lnAge + iif(%treatedBp, 29.00 * %lnSbp + (-6.59) * %lnAge * %lnSbp, 28.18 * %lnSbp + (-6.42) * %lnAge * %lnSbp) + iif(%smoker, 0.76, 0) + iif(%treatedDm, 0.97 * %lnGlu, 0.80 * %lnGlu) + 0.32 * %lnTc + 21.24 * %lnBmi + (-5.00) * %lnAge * %lnBmi + 1.27 * %lnQrs)))"
