                "language": "text/fhirpath",
                "expression": "0.08618 * (%resource.item.where(linkId='inputs').item.where(linkId='age').answer.value / 10) + iif(%resource.item.where(linkId='inputs').item.where(linkId='sex').answer.value.code = 'male', 0.08527, 0) + 0.47000 * iif(%resource.item.where(linkId='inputs').item.where(linkId='nyha_class').answer.value.code = 'I', 1, iif(%resource.item.where(linkId='inputs').item.where(linkId='nyha_class').answer.value.code = 'II', 2, iif(%resource.item.where(linkId='inputs').item.where(linkId='nyha_class').answer.value.code = 'III', 3, 4))) + 0.02956 * (100 / %resource.item.where(linkId='inputs').item.where(linkId='ejection_fraction').answer.value) + iif(%resource.item.where(linkId='inputs').item.where(linkId='ischemic_etiology').answer.value.code = 'yes', 0.30310, 0) + (-0.13127) * (iif(%resource.item.where(linkId='inputs').item.where(linkId='systolic_bp').answer.value > 160, 160, %resource.item.where(linkId='inputs').item.where(linkId='systolic_bp').answer.value) / 10) + 0.16382 * ((%resource.item.where(linkId='inputs').item.where(linkId='furosemide_dose').answer.value + 2 * %resource.item.where(linkId='inputs').item.where(linkId='torsemide_dose').answer.value + 26.7 * %resource.item.where(linkId='inputs').item.where(linkId='bumetanide_dose').answer.value + 40 * %resource.item.where(linkId='inputs').item.where(linkId='metolazone_dose').answer.value + 3.2 * %resource.item.where(linkId='inputs').item.where(linkId='hctz_dose').answer.value) / %resource.item.where(linkId='inputs').item.where(linkId='weight_kg').answer.value) + 0.04879 * (138 - iif(%resource.item.where(linkId='inputs').item.where(linkId='sodium').answer.value > 138, 138, %resource.item.where(linkId='inputs').item.where(linkId='sodium').answer.value)) + iif(%resource.item.where(linkId='inputs').item.where(linkId='hemoglobin').answer.value < 16, 0.11688 * (16 - %resource.item.where(linkId='inputs').item.where(linkId='hemoglobin').answer.value), 0.28968 * (%resource.item.where(linkId='inputs').item.where(linkId='hemoglobin').answer.value - 16)) + (-0.10870) * (iif(%resource.item.where(linkId='inputs').item.where(linkId='lymphocytes_pct').answer.value > 47, 47, %resource.item.where(linkId='inputs').item.where(linkId='lymphocytes_pct').answer.value) / 5) + 0.06203 * iif(%resource.item.where(linkId='inputs').item.where(linkId='uric_acid').answer.value < 3.4, 3.4, %resource.item.where(linkId='inputs').item.where(linkId='uric_acid').answer.value) + 0.79121 * (100 / %resource.item.where(linkId='inputs').item.where(linkId='total_cholesterol').answer.value) + iif(%resource.item.where(linkId='inputs').item.where(linkId='ace_inhibitor').answer.value.code = 'yes', -0.26136, 0) + iif(%resource.item.where(linkId='inputs').item.where(linkId='arb').answer.value.code = 'yes', -0.16252, 0) + iif(%resource.item.where(linkId='inputs').item.where(linkId='beta_blocker').answer.value.code = 'yes', -0.41552, 0) + iif(%resource.item.where(linkId='inputs').item.where(linkId='statin').answer.value.code = 'yes', -0.46204, 0) + iif(%resource.item.where(linkId='inputs').item.where(linkId='allopurinol').answer.value.code = 'yes', 0.45178, 0) + iif(%resource.item.where(linkId='inputs').item.where(linkId='k_sparing').answer.value.code = 'yes', -0.30111, 0) + iif(%resource.item.where(linkId='inputs').item.where(linkId='device').answer.value.code = 'icd', -0.31471, iif(%resource.item.where(linkId='inputs').item.where(linkId='device').answer.value.code = 'bivent_icd', -0.23572, iif(%resource.item.where(linkId='inputs').item.where(linkId='device').answer.value.code = 'bivent_pacer', -0.4463, 0)))"
              }
            },
